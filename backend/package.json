{
  "name": "expensio-backend",
  "version": "1.0.0",
  "description": "Expensio - Full Stack Expense Tracker API built with Node.js and Express",
  "main": "server.js",
  "scripts": {
    "start":   "node server.js",
    "dev":     "nodemon server.js",
    "test":    "jest --coverage --forceExit",
    "test:ci": "jest --coverage --forceExit --ci"
  },
  "keywords": ["expense", "tracker", "nodejs", "express", "devops"],
  "author": "Your Name",
  "license": "MIT",
  "dependencies": {
    "cors":    "^2.8.5",
    "express": "^4.18.2",
    "helmet":  "^7.1.0",
    "morgan":  "^1.10.0"
  },
  "devDependencies": {
    "jest":       "^29.7.0",
    "nodemon":    "^3.0.2",
    "supertest":  "^6.3.4"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment":     "node",
    "coverageDirectory":   "coverage",
    "collectCoverageFrom": ["*.js", "!jest.config.js"],
    "reporters": [
      "default",
      ["jest-junit", {
        "outputDirectory": ".",
        "outputName":      "test-results.xml"
      }]
    ]
  }
}
